<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="720.0" prefWidth="1280.0"
            style="-fx-background-color: #1E3248;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="game.gui.controller.GameController">


    <top>
        <VBox style="-fx-background-color: #0D1B2A;" BorderPane.alignment="CENTER">
            <HBox alignment="CENTER" spacing="20" style="-fx-padding: 7 20;">
                <Label fx:id="turnIndicator" text="YOUR TURN"
                       style="-fx-text-fill: #FFD700; -fx-font-size: 18px; -fx-font-weight: bold;" />
                <Label text="|" style="-fx-text-fill: #2E4A7A; -fx-font-size: 18px;" />
                <Label fx:id="statusLabel" text="Click the dice to roll!"
                       style="-fx-text-fill: #CCCCEE; -fx-font-size: 14px;" />
            </HBox>
            <HBox alignment="CENTER" style="-fx-padding: 0 20 5 20;">
                <Label fx:id="eventLabel" text=""
                       style="-fx-text-fill: #FFD700; -fx-font-size: 12px; -fx-font-style: italic;"
                       maxWidth="900" />
            </HBox>
        </VBox>
    </top>


    <left>
        <VBox fx:id="playerPanel" prefWidth="220.0"
              style="-fx-background-color: #142236; -fx-padding: 10; -fx-spacing: 6;"
              BorderPane.alignment="CENTER" />
    </left>


    <center>
        <StackPane fx:id="boardContainer"
                   style="-fx-background-color: #1E3248;"
                   BorderPane.alignment="CENTER" />
    </center>

    <right>
        <VBox fx:id="opponentPanel" prefWidth="220.0"
              style="-fx-background-color: #142236; -fx-padding: 10; -fx-spacing: 6;"
              BorderPane.alignment="CENTER" />
    </right>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #0D1B2A; -fx-padding: 10 15;"
              BorderPane.alignment="CENTER">


            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="powerupButton" text="USE POWERUP (500)"
                    prefWidth="185.0" prefHeight="40.0"
                    style="-fx-background-color: #7A4A1E; -fx-text-fill: #FFD700;
                        -fx-font-size: 12px; -fx-font-weight: bold;
                        -fx-background-radius: 8; -fx-cursor: hand;" />

            <Region HBox.hgrow="ALWAYS" />


            <VBox spacing="3" alignment="CENTER_RIGHT">
                <Label text="P = You    O = Opponent    Win: cell 100 + 1000 energy"
                       style="-fx-text-fill: #CCCCEE; -fx-font-size: 10px;" />
                <Label text="Cheats: W = player wins   E = +energy   L = opponent wins"
                       style="-fx-text-fill: #4A5A6A; -fx-font-size: 9px;" />
            </VBox>


            <Button fx:id="menuButton" text="☰  MENU"
                    prefWidth="110" prefHeight="40"
                    style="-fx-background-color: #1A2E4A; -fx-text-fill: #FFD700;
                        -fx-font-size: 12px; -fx-font-weight: bold;
                        -fx-background-radius: 8;
                        -fx-border-color: #2E4A7A; -fx-border-width: 1;
                        -fx-border-radius: 8; -fx-cursor: hand;" />

        </HBox>
    </bottom>

</BorderPane>
